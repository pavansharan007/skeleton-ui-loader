{
  "name": "skeleton-ui-loader",
  "version": "0.1.5",
  "description": "Zero-config React skeleton loader generated from real DOM structure.",
  "author": "Pavan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pavansharan007/skeleton-ui-loader.git"
  },
  "bugs": {
    "url": "https://github.com/pavansharan007/skeleton-ui-loader/issues"
  },
  "homepage": "https://github.com/pavansharan007/skeleton-ui-loader#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "node ./scripts/copy-css.cjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "react",
    "skeleton",
    "loader",
    "shimmer",
    "ui",
    "typescript"
  ],
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
